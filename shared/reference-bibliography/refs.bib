@book{Podolsky2018,
  author    = {Podolsk{\'y}, Ji{\v r}{\'\i}},
  title     = {Teoretick{\'a} mechanika ve t{\v r}ech knih{\'a}ch},
  publisher = {Matfyzpress},
  address   = {Praha},
  year      = {2018},
  isbn      = {978-80-7378-499-7},
  language  = {Czech},
  audience  = {CS readers; supplementary for EN readers},
  note      = {Modern Czech-language presentation of analytical mechanics in frame-invariant form. Charles University author known for general-relativity work; brings modern coordinate-free perspective to the classical material. AUDIENCE NOTE: this is the most up-to-date Czech-language reference for analytical mechanics in modern frame-invariant form; in `docs/canonical/en/` chapters, cite as supplementary "for Czech-reading audiences" only --- not as a primary referral, because the audience-language mismatch would frustrate EN readers who cannot access it. Becomes the primary referral in `docs/canonical/cs/` translations (forthcoming). Project owner holds paper copy. SPECIFIC EQUATION ANCHORS (catalogued 2026-05-24 from project owner's photographed pages 137-162): Kapitola 6 Kinematika tuh{\'e}ho t{\v e}lesa --- {\S}6.1 vectors and tensors (orthonormal basis, transformation matrices A, classical-vs-modern tensor definitions); {\S}6.2 relativity of rotational motion (inertial vs body-fixed/korotuj{\'\i}c{\'\i} basis); {\S}6.3 Eqs.~(6.2) $\Omega' = (dA/dt) A^t$ (body-frame angular-velocity tensor), (6.4) $\Omega'_{ij} \equiv \Omega(\mathbf{e}'_i, \mathbf{e}'_j)$ (body-frame components), (6.5) antisymmetry from orthogonality, (6.6)-(6.7) dual pseudo-vector, (6.8) boxed transport equation $(d\mathbf{w}/dt)|_{\mathrm{prostor}} = (d\mathbf{w}/dt)|_{\mathrm{t{\v e}leso}} + \boldsymbol\Omega \times \mathbf{w}$, (6.9)-(6.10) spatial-frame trivialisation $\Omega = A^t (dA/dt)$, (6.13) angular-velocity composition $\Omega^C = \Omega^B + \Omega^A$; {\S}6.4 Eqs.~(6.11) elementary rotation example, (6.14)-(6.16) intrinsic-ZXZ Euler-angle matrices D/C/B with $A = BCD$, (6.17) boxed Euler kinematic equations $\Omega_x = \dot\varphi \sin\vartheta \sin\psi + \dot\vartheta \cos\psi$ etc.; {\S}6.5 Eq.~(6.18) non-inertial acceleration decomposition (Euler + Coriolis + centripetal/doosov{\'e}). Kapitola 7 Dynamika tuh{\'e}ho t{\v e}lesa --- {\S}7.1 Eqs.~(7.3) bilinear inertia-tensor definition $I(\boldsymbol\xi, \boldsymbol\Omega) \equiv \sum_a m^a (\boldsymbol\xi \times \mathbf{r}^a) \cdot (\boldsymbol\Omega \times \mathbf{r}^a)$, (7.6) $T = \tfrac{1}{2} I(\boldsymbol\Omega, \boldsymbol\Omega)$, (7.8) component form $I_{ij} = \int (\delta_{ij} x_k x_k - x_i x_j)\, \rho\, dV$, (7.9) boxed $L_i = I_{ij} \Omega_j$ + $T = \tfrac{1}{2} I_{ij} \Omega_i \Omega_j$, (7.10) principal-axis simplification, (7.11) directional moment $I_{\mathbf{n}} = I_{ij} n_i n_j$, (7.12) Steiner tensor theorem; {\S}7.2 boxed Eq.~(7.15) Euler dynamic equations $I_1 \dot\Omega_x - (I_2 - I_3) \Omega_y \Omega_z = M_x$ etc.; {\S}7.3 derivation via Lagrangian formalism with Euler angles --- direct CS-language anchor for our Chapter 04 (Euler-Lagrange + Euler-Poincar{\'e} reduction). Kapitola 8 Aplikace: setrva{\v c}n{\'\i}ky --- {\S}8.1 Eqs.~(8.1)-(8.2) free symmetric top, regular precession of body-axis cone (direct anchor for our Phase 1 D8 test\_symmetric\_top.f90 fixture testbed); {\S}8.2 top with friction $\mathbf{M} = -k \boldsymbol\Omega$; {\S}8.3 heavy symmetric top with fixed point (Lagrange top), Eqs.~(8.10)-(8.15) Lagrangian formalism with cyclic coordinates $\psi, \varphi$, effective potential $V_{\mathrm{ef}}(\vartheta)$, three precession cases (a)/(b)/(c) on the sphere --- direct precedent for our gravity-gradient libration testbed analysis (Phase 2 scope).}
}


