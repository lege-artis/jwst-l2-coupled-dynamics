@book{ThorneBlandford2017,
  author    = {Thorne, Kip S. and Blandford, Roger D.},
  title     = {Modern Classical Physics: Optics, Fluids, Plasmas, Elasticity, Relativity, and Statistical Physics},
  publisher = {Princeton University Press},
  year      = {2017},
  isbn      = {978-0-691-15902-7},
  note      = {Modern reference for the geometric-viewpoint / coordinate-free framing of classical-physics structures (tensor algebra, stress tensor, inertia tensor as an example). PDF inspection 2026-05-23 confirmed: this edition (subtitled "Optics, Fluids, Plasmas, Elasticity, Relativity, and Statistical Physics") does NOT contain a rigid-body-mechanics chapter — the König decomposition and inertia-tensor mass-distribution derivation belong to a companion mechanics volume not bundled with the uploaded edition. Specific equation-level back-fill citations resolved 2026-05-23: §1.1.1 + §1.3 (inertia tensor as a coordinate-free vector-valued linear function $\mathbf{I}(\,\cdot\,, \boldsymbol{\omega}) = \mathbf{J}$, complementing the coordinate derivation in our Chapter 02 §2.4); §27.5.1-§27.5.2 + Eqs. (27.50)-(27.53) (Cartesian multipole expansion of the Newtonian gravitational potential as scaffolding for gravitational-wave-source theory, anchoring our Chapter 03 §3.2 + §3.4.3 derivations). Note: T&B's mass quadrupole moment $\mathcal{I}_{jk}$ in Eq. (27.53) uses prefactor 1/3; our Chapter 03 follows the Jackson convention with prefactor 3, giving $\mathbf{Q}_{jk} = 3\, \mathcal{I}_{jk}$.}
}

